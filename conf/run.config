// Change this line to switch datasets
params.validationSchemaIgnoreParams = 'dataset'
params.dataset = 'airway'

// Resource ceilings for a 16 GB machine — applies to every run
process {
    resourceLimits = [ cpus: 6, memory: 14.GB, time: 48.h ]
}

profiles {
    // fetchngs: downloads FASTQ and builds rnaseq samplesheet
    download {
        params {
            input =             "${launchDir}/assets/${params.dataset}_ids.csv"
            outdir =            "results/${params.dataset}"
            nf_core_pipeline =  'rnaseq'
        }
    }

    // rnaseq: quantify using the samplesheet generated by fetchngs
    quant {
        params {
            input = "${launchDir}/results/${params.dataset}/samplesheet/samplesheet.csv"
            outdir = "results/${params.dataset}_rnaseq"
            genome = 'GRCh38'
            // Was having memory issues which were crashing wsl
            pseudo_aligner = 'salmon'
            skip_alignment = true
        }
    }
}